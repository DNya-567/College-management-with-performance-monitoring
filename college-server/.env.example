# ── Server ──
NODE_ENV=development
PORT=5000

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=college_db

# ── Auth ──
JWT_SECRET=generate_a_long_random_string_here
JWT_EXPIRES_IN=8h

# ── CORS (comma-separated allowed origins) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

