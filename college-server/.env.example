# =============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this to .env or .env.production
# Fill in your values below
# =============================================

# ── Server Configuration ──
NODE_ENV=development                        # development or production
PORT=5000                                    # Server port
DEBUG=false                                  # Enable debug mode

# ── PostgreSQL Database ──
DB_HOST=localhost                            # Database host
DB_PORT=5432                                 # PostgreSQL port
DB_NAME=college_db                           # Database name
DB_USER=postgres                             # Database user
DB_PASSWORD=your_secure_password_here        # Use strong password!
DB_POOL_MIN=5                                # Min pool connections
DB_POOL_MAX=50                               # Max pool connections
DB_CONNECTION_TIMEOUT=5000                   # Connection timeout (ms)
DB_IDLE_TIMEOUT=30000                        # Idle timeout (ms)

# ── Authentication & JWT ──
JWT_SECRET=your_very_secure_random_string_minimum_32_chars_here
JWT_EXPIRES_IN=8h                            # Token expiration time
JWT_ALGORITHM=HS256                          # Signing algorithm

# ── CORS (comma-separated allowed origins) ──
# Development: http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ── Email Configuration (for password reset, announcements) ──
SMTP_HOST=smtp.gmail.com                     # SMTP server
SMTP_PORT=587                                # SMTP port (587 for TLS)
SMTP_USER=noreply@yourdomain.com             # Email sender
SMTP_PASSWORD=your_app_password_here         # App-specific password
SMTP_FROM=noreply@yourdomain.com             # From address
SMTP_SECURE=true                             # Use TLS

# ── Logging ──
LOG_LEVEL=info                               # error, warn, info, debug
LOG_DIR=./logs                               # Log file directory
LOG_FILE_SIZE=10485760                       # Max log file size (10MB)
LOG_FILE_RETENTION=7                         # Days to retain logs

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000                  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100                  # Max requests per window
RATE_LIMIT_KEY_PREFIX=rl_                    # Redis key prefix

# ── Request Timeout ──
REQUEST_TIMEOUT_MS=30000                     # 30 seconds

# ── Admin Credentials (for seeding) ──
ADMIN_PASSWORD=changeme123                   # Change after first login

# ── Session ──
SESSION_SECRET=your_session_secret_here      # Use strong random string
SESSION_TIMEOUT_MS=86400000                  # 24 hours

# ── Feature Flags ──
ENABLE_STUDENT_REGISTRATION=true             # Allow new registrations
ENABLE_EMAIL_NOTIFICATIONS=false              # Send emails (if false, skip SMTP setup)
ENABLE_ATTENDANCE_VALIDATION=true            # Validate attendance data

# ── Pagination ──
DEFAULT_PAGE_SIZE=20                         # Default items per page
MAX_PAGE_SIZE=100                            # Max items per page
